# Supabase — copiar do dashboard em app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Integração n8n
N8N_API_KEY=           # Chave secreta que o n8n usa para acessar a API do dashboard
N8N_WEBHOOK_URL=       # URL do webhook n8n para iniciar buscas
